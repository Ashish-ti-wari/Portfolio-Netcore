@{
    ViewData["Title"] = "Work & Projects - Ashish";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .section-padding {
        padding: 7rem 0 5rem;
    }

    .page-header {
        text-align: center;
        margin-bottom: 4rem;
        position :static ;
        display : flex ; align-items :center ; justify-content :center ;
    }

    .page-title {
        font-size: 2rem;
       padding :1rem 0 1rem 0 ;
    }

    .page-subtitle {
        color: var(--muted);
        font-size: 1.15rem;
        max-width: 680px;
        margin: 0 auto;
        text-align: center ;

    }

    .project-grid {
        display: grid;
         grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 2.2rem;
        margin-top: 3rem;
    }

    .project-card {
        background: var(--glass);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: 1.4rem;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .project-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    .project-image {
        height: 220px;
        background: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        font-size: 1.3rem;
        font-weight: 500;
        font-style: italic;
        text-align: center;
        padding: 0 1rem;
    }

    .project-content {
        padding: 1.8rem 1.9rem 2.2rem;
    }

    .project-title {
        font-size: 1.5rem;
        margin-bottom: 0.9rem;
    }

    .project-description {
        font-size: 1.05rem;
        line-height: 1.6;
        margin-bottom: 1.4rem;
        color: var(--text-secondary);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .tag {
        padding: 0.35rem 0.9rem;
        background: rgba(37,99,235,0.1);
        color: var(--accent);
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .section-padding {
            padding: 5rem 0 3.5rem;
        }
        .page-title {
            font-size: 2.6rem;
        }
        .project-grid {
            gap: 2rem;
        }
    }

    @@media (max-width: 480px) {
        .project-grid {
            gap: 1.8rem;
        }
        .project-image {
            height: 180px;
            font-size: 1.1rem;
        }
        .project-content {
            padding: 1.6rem 1.5rem 2rem;
        }
    }
</style>

<section class="section-padding">
    <div class="container">
        <header class="page-header">
            <h1 class="page-title">My Work</h1>
           
        </header>
         <p class="page-subtitle">
                Some of the projects I've worked on recently
            </p>
        <div class="project-grid">

            <!-- Project 1 -->
            <div class="project-card">
                <div class="project-image">Registration Form</div>
                <div class="project-content">
                    <h3 class="project-title">Registration Form</h3>
                    <p class="project-description">
                       Full-featured online registration form for students, including signup, login, payment, application form, and password generation from the database, and many more."
                    </p>
                    <div class="tags">
                        <span class="tag">ASP.NET Core 8</span>
                        <span class="tag">EF Core</span>
                        <span class="tag">Razor Pages</span>
                        <span class="tag">SQL Server</span>
                    </div>
                </div>
            </div>

            <!-- Project 2 -->
            <div class="project-card">
                <div class="project-image">Task Management App</div>
                <div class="project-content">
                    <h3 class="project-title">Task & Project Management</h3>
                    <p class="project-description">
                        Kanban-style board with drag & drop, real-time updates, team collaboration, attachments, comments and notifications.
                    </p>
                    <div class="tags">
                        <span class="tag">Blazor Server</span>
                        <span class="tag">SignalR</span>
                        <span class="tag">.NET 8</span>
                        <span class="tag">PostgreSQL</span>
                    </div>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="project-card">
                <div class="project-image">Personal Finance Tracker</div>
                <div class="project-content">
                    <h3 class="project-title">Personal Finance Tracker</h3>
                    <p class="project-description">
                        Expense/income tracking, budget planning, visual reports (charts), category management, export to PDF/Excel, secure authentication.
                    </p>
                    <div class="tags">
                        <span class="tag">ASP.NET Core MVC</span>
                        <span class="tag">Chart.js</span>
                        <span class="tag">Identity</span>
                        <span class="tag">Azure Blob</span>
                    </div>
                </div>
            </div>

            <!-- Add more project cards here if needed -->

        </div>
    </div>
</section>