@{
    ViewData["Title"] = "Work & Projects - Ashish";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 2.2rem;
        margin-top: 3rem;
    }

    .project-card {
        background: var(--glass);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: 1.4rem;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .project-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    .project-image {
        height: 220px;
        background: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        font-size: 1.1rem;
        font-style: italic;
    }

    .project-content {
        padding: 1.8rem 1.9rem 2.2rem;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.2rem;
    }

    .tag {
        padding: 0.35rem 0.9rem;
        background: rgba(37,99,235,0.1);
        color: var(--accent);
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
    }

    @@media (max-width: 480px) {
        .project-grid { gap: 1.8rem; }
        .project-image { height: 180px; }
    }
</style>

<section style="padding: 7rem 0 5rem;">
    <div class="container">
        <h1 style="font-size: 3.2rem; text-align: center; margin-bottom: 1rem;">My Work</h1>
        <p style="text-align: center; color: var(--muted); font-size: 1.15rem; margin-bottom: 4rem;">
            Some of the projects I've worked on recently
        </p>

        <div class="project-grid">
            <!-- Project 1 -->
            <div class="project-card">
                <div class="project-image">E-Commerce Platform</div>
                <div class="project-content">
                    <h3 style="font-size: 1.5rem; margin-bottom: 0.9rem;">E-Commerce Platform</h3>
                    <p>Full-featured online store with product catalog, cart, checkout, admin dashboard, payment integration (Razorpay/Stripe simulation), order tracking.</p>
                    <div class="tags">
                        <span class="tag">ASP.NET Core 8</span>
                        <span class="tag">EF Core</span>
                        <span class="tag">Razor Pages</span>
                        <span class="tag">SQL Server</span>
                    </div>
                </div>
            </div>

            <!-- Project 2 -->
            <div class="project-card">
                <div class="project-image">Task Management App</div>
                <div class="project-content">
                    <h3 style="font-size: 1.5rem; margin-bottom: 0.9rem;">Task & Project Management</h3>
                    <p>Kanban-style board with drag & drop, real-time updates, team collaboration, attachments, comments and notifications.</p>
                    <div class="tags">
                        <span class="tag">Blazor Server</span>
                        <span class="tag">SignalR</span>
                        <span class="tag">.NET 8</span>
                        <span class="tag">PostgreSQL</span>
                    </div>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="project-card">
                <div class="project-image">Personal Finance Tracker</div>
                <div class="project-content">
                    <h3 style="font-size: 1.5rem; margin-bottom: 0.9rem;">Personal Finance Tracker</h3>
                    <p>Expense/income tracking, budget planning, visual reports (charts), category management, export to PDF/Excel, secure authentication.</p>
                    <div class="tags">
                        <span class="tag">ASP.NET Core MVC</span>
                        <span class="tag">Chart.js</span>
                        <span class="tag">Identity</span>
                        <span class="tag">Azure Blob</span>
                    </div>
                </div>
            </div>

            <!-- You can add 1–3 more cards here -->
        </div>
    </div>
</section>