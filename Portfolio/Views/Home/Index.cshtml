@{
    ViewData["Title"] = "Ashish | .NET Developer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero {
        min-height: 90vh;
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
        color: white;
        display: flex;
        align-items: center;
        text-align: center;
        padding: 4rem 0;
    }

    .typing {
        font-size: 2.6rem;
        font-weight: 600;
        min-height: 4.6rem;
        border-right: 4px solid rgba(255,255,255,0.7);
        white-space: nowrap;
        overflow: hidden;
       
        display: inline-block;
    }

    .section {
        padding: 6rem 0;
    }

    .glass-card {
        background: var(--glass);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        padding: 2.5rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
}

/* Force single column + smaller min on very narrow screens */
@@media (max-width: 360px) {
    .grid-3 {
        grid-template-columns: 1fr;           /* always 1 column */
        gap: 1.6rem;
    }

    .glass-card {
        min-width: 0;                         /* allow shrinking below content size */
        overflow: hidden;                     /* prevent any internal overflow */
    }
}

    @@media (max-width: 768px) {
        .hero { min-height: 80vh; padding: 6rem 0 4rem; }
        .typing { font-size: 2rem; }
        h1 { font-size: 2.8rem; }
        .section { padding: 4rem 0; }
    }
     @@media (max-width: 325px) {
   
        .glass-card{
            padding :1.5rem ;
        }
    }
    @@media (max-width : 468px){
        .typing {
          font-size : 1.5rem ;
        }
    }
</style>

<section class="hero">
    <div class="container">
        <h1>Hi, I'm Ashish Tiwari</h1>
        <div class="typing" id="typing"></div>
        <p style="font-size:1.35rem; max-width:680px; margin:1.8rem auto; opacity:0.92;">
            Full-stack .NET developer creating clean, scalable web applications from Delhi
        </p>
        <div style="margin-top:2.8rem; display:flex; gap:1.4rem; justify-content:center; flex-wrap:wrap;">
            <a href="/projects" class="btn">View Work</a>
            <a href="#" class="btn btn-outline">Download CV</a>
        </div>
    </div>
</section>

<section class="section" id="about">
    <div class="container">
        <h2 style="font-size:2.8rem; text-align:center; margin-bottom:3rem;">About Me</h2>
        <div class="glass-card" style="max-width:780px; margin:0 auto;">
            <p style="font-size:1.15rem; margin-bottom:1.5rem;">
                Passionate .NET developer with 3+ years of experience building enterprise-grade web applications.
                I enjoy solving real problems with clean architecture, modern C#, Blazor, EF Core and Azure.
            </p>
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1.5rem; margin-top:2rem;">
                <div><strong>Location</strong><br>Delhi, India</div>
                <div><strong>Focus</strong><br>ASP.NET Core • Blazor • Azure</div>
                <div><strong>Currently</strong><br>Exploring .NET 9 & Minimal APIs</div>
            </div>
        </div>
    </div>
</section>

<section class="section" id="skills" style="background:var(--card);">
    <div class="container">
        <h2 style="font-size:2.8rem; text-align:center; margin-bottom:3rem;">Skills</h2>
        <div class="grid-3">
            <div class="glass-card" style="text-align:center;">
                <i class="fa-brands fa-microsoft" style="font-size:3.5rem; color:var(--accent); margin-bottom:1rem;"></i>
                <h3>ASP.NET Core</h3>
            </div>
            <div class="glass-card" style="text-align:center;">
                <i class="fa-solid fa-c" style="font-size:3.5rem; color:#7c3aed; margin-bottom:1rem;"></i>
                <h3>C#</h3>
            </div>
            <div class="glass-card" style="text-align:center;">
                <i class="fa-solid fa-database" style="font-size:3.5rem; color:#10b981; margin-bottom:1rem;"></i>
                <h3>SQL Server / EF Core</h3>
            </div>
            <div class="glass-card" style="text-align:center;">
                <i class="fa-solid fa-cloud" style="font-size:3.5rem; color:var(--accent); margin-bottom:1rem;"></i>
                <h3>Azure</h3>
            </div>
            <div class="glass-card" style="text-align:center;">
                <i class="fa-brands fa-js" style="font-size:3.5rem; color:#f59e0b; margin-bottom:1rem;"></i>
                <h3>JavaScript / TypeScript</h3>
            </div>
            <div class="glass-card" style="text-align:center;">
                <i class="fa-solid fa-code" style="font-size:3.5rem; color:#8b5cf6; margin-bottom:1rem;"></i>
                <h3>Blazor</h3>
            </div>
        </div>
    </div>
</section>

<section class="section" id="projects">
    <div class="container">
        <h2 style="font-size:2.8rem; text-align:center; margin-bottom:3rem;">Featured Work</h2>
        <div class="grid-3">
            <div class="glass-card">
                <h3>E-Commerce Platform</h3>
                <p>Full-featured online store with payment integration, admin panel and responsive design.</p>
                <div style="margin-top:1.2rem; display:flex; gap:0.6rem; flex-wrap:wrap;">
                    <span style="padding:0.4rem 0.9rem; background:rgba(37,99,235,0.1); border-radius:999px; font-size:0.9rem;">ASP.NET Core</span>
                    <span style="padding:0.4rem 0.9rem; background:rgba(139,92,246,0.1); border-radius:999px; font-size:0.9rem;">EF Core</span>
                </div>
            </div>
            <!-- Add 2–3 more project cards here -->
        </div>
    </div>
</section>

<section class="section" id="contact" style="background:var(--card);">
    <div class="container" style="max-width:700px;">
        <h2 style="font-size:2.8rem; text-align:center; margin-bottom:3rem;">Get in Touch</h2>
        <form action="https://formspree.io/f/your-id" method="POST" style="display:grid; gap:1.4rem;">
            <input type="text" name="name" placeholder="Your Name" required style="padding:1rem; border:1px solid var(--border); border-radius:10px; background:var(--glass);">
            <input type="email" name="email" placeholder="Your Email" required style="padding:1rem; border:1px solid var(--border); border-radius:10px; background:var(--glass);">
            <textarea name="message" rows="6" placeholder="Your Message" required style="padding:1rem; border:1px solid var(--border); border-radius:10px; background:var(--glass); resize:vertical;"></textarea>
            <button type="submit" class="btn" style="padding:1.1rem;">Send Message</button>
        </form>
        <p style="text-align:center; margin-top:2rem; color:var(--muted);">
            or email me directly: ashish@example.com
        </p>
    </div>
</section>

@section Scripts {
    <script>
        const phrases = [
            "Full-Stack .NET Developer",
            "Building Scalable Apps",
            "Clean Architecture Lover",
            "Delhi, India"
        ];

        let i = 0, char = 0;
        const typing = document.getElementById("typing");

        function type() {
            if (i >= phrases.length) i = 0;
            const str = phrases[i];
            typing.textContent = str.substring(0, char++);
            if (char > str.length) {
                char = 0;
                i++;
                setTimeout(type, 1800);
            } else {
                setTimeout(type, 70);
            }
        }

        setTimeout(() => {
            typing.textContent = "";
            type();
        }, 800);
    </script>
}