@{
    ViewData["Title"] = "About Me - Ashish";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .about-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 3rem;
        align-items: center;
    }

    .profile-photo {
        border-radius: 1.5rem;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border: 8px solid var(--card);
    }

        .profile-photo img {
            width: 100%;
            height: auto;
            display: block;
        }

    .facts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.6rem;
        margin-top: 2.5rem;
    }

    .fact-item {
        background: var(--glass);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 1.6rem;
        text-align: center;
    }

        .fact-item strong {
            display: block;
            font-size: 1.4rem;
            color: var(--accent);
            margin-bottom: 0.6rem;
        }

    @@media (max-width: 768px) {
        .profile-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .profile-photo {
            max-width: 360px;
            margin: 0 auto 2rem;
        }
    }
</style>

<section style="padding: 7rem 0 5rem;">
    <div class="container about-container">
        <h1 style="font-size: 3.2rem; text-align: center; margin-bottom: 4rem;">About Me</h1>

        <div class="profile-grid">
            <div class="profile-photo">
                <!-- Replace with your real photo -->
                <img src="~/img/ashishport.jpeg" alt="Ashish" />
            </div>

            <div>
                <h2 style="font-size: 2.4rem; margin-bottom: 1.4rem;">Hi, I'm Ashish</h2>

                <p style="font-size: 1.18rem; line-height: 1.7; margin-bottom: 1.8rem;">
                    I'm a passionate .NET developer from Delhi, India.<br>
                    I really enjoy building clean, fast and user-friendly web applications —
                    and I've been doing it for the last couple of Months.
                </p>

                <p style="font-size: 1.18rem; line-height: 1.7; margin-bottom: 2rem;">
                  
                    I'm always excited to learn new tools and technologies — whether it's a better way to structure code,
                    a new library that makes life easier, or something completely different that solves real problems better.
                    Clean architecture, good performance, security, and writing code that other developers actually enjoy reading
                    are things I care about a lot.
                </p>

                <div class="facts-grid">
                    <div class="fact-item">
                        <strong>Delhi, India</strong>
                        Based in
                    </div>
                    <div class="fact-item">
                        <strong>2 Months</strong>
                        Hands-on experience
                    </div>
                    <div class="fact-item">
                        <strong>.NET • React • SQL</strong>
                        Core stack
                    </div>
                    <div class="fact-item">
                        <strong>Always learning</strong>
                        Open to new opportunities
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>